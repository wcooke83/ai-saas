{
  "name": "vocui",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev -p 3030",
    "dev:log": "next dev -p 3030 2>&1 | node scripts/tee.js server.log",
    "e2e:dev": "fuser -k 3030/tcp 2>/dev/null; npm run clean && npm run dev:log",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rimraf .next node_modules/.cache",
    "clean:dev": "fuser -k 3030/tcp 2>/dev/null; npm run clean && npm run dev",
    "db:gen-types": "supabase gen types typescript --local > src/types/database.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "stripe:listen": "stripe listen --forward-to localhost:3030/api/stripe/webhook",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@slack/web-api": "^7.13.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "ai": "^6.0.3",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.11.0",
    "next": "^15.1.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.3",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.6.0",
    "sonner": "^2.0.7",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "imapflow": "^1.2.16",
    "postcss": "^8.4.49",
    "rimraf": "^6.1.2",
    "supabase": "^2.78.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.1"
  }
}
