{
  "name": "vocui-agent",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "e2e": "set -a && . .maestro/.env && set +a && maestro test .maestro/flows",
    "e2e:auth": "set -a && . .maestro/.env && set +a && maestro test .maestro/flows/01_auth.yaml",
    "e2e:inbox": "set -a && . .maestro/.env && set +a && maestro test .maestro/flows/02_inbox.yaml",
    "e2e:chatbots": "set -a && . .maestro/.env && set +a && maestro test .maestro/flows/03_chatbots.yaml",
    "e2e:conversations": "set -a && . .maestro/.env && set +a && maestro test .maestro/flows/04_conversation_detail.yaml",
    "e2e:settings": "set -a && . .maestro/.env && set +a && maestro test .maestro/flows/05_settings.yaml",
    "e2e:knowledge": "set -a && . .maestro/.env && set +a && maestro test .maestro/flows/06_knowledge.yaml"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/slider": "^4.5.5",
    "@react-navigation/drawer": "^7.9.8",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.56.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-haptics": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "~15.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "^0.27.5",
    "fast-deep-equal": "^3.1.3",
    "metro": "~0.81.0",
    "nanoid": "^5.1.7",
    "nativewind": "^4.0.1",
    "query-string": "^7.1.3",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-native": "^0.76.9",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "^0.19.13",
    "tailwindcss": "^3.4.0",
    "use-latest-callback": "^0.3.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.3.0",
    "typescript": "^5.3.0"
  }
}
