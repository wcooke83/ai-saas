# ===================
# APP
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AI SaaS Tools"

# ===================
# SUPABASE
# ===================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================
# AI PROVIDERS
# ===================
# Anthropic (Primary - Claude)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (Fallback)
OPENAI_API_KEY=sk-xxx

# DeepSeek (High performance, low cost)
DEEPSEEK_API_KEY=sk-xxx

# Google Gemini (Free tier available, supports embeddings)
GOOGLE_API_KEY=AIzaSy-xxx

# ===================
# STRIPE
# ===================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Price IDs (create in Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# ===================
# RATE LIMITING (Optional - Upstash Redis)
# ===================
# Leave empty to use in-memory rate limiting (dev only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===================
# CORS (Production)
# ===================
# Comma-separated list of allowed origins for API access
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ===================
# OPTIONAL: ANALYTICS
# ===================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ===================
# OPTIONAL: ERROR TRACKING
# ===================
SENTRY_DSN=

# ===================
# E2E TESTING
# ===================
E2E_TEST_SECRET=
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_VISITOR_EMAIL=
E2E_VISITOR_PASSWORD=
SUPABASE_PROJECT_REF=

# ===================
# SMTP (Ticket emails)
# ===================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
